{
  "kind": "collectionType",
  "collectionName": "fieis",
  "info": {
    "singularName": "fiei",
    "pluralName": "fieis",
    "displayName": "Fiel"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "cpf": {
      "type": "string",
      "maxLength": 11,
      "required": true
    },
    "sexo": {
      "type": "string",
      "required": true
    },
    "nome": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "dizimistaId": {
      "type": "biginteger",
      "required": true,
      "unique": true
    },
    "data_nascimento": {
      "type": "date",
      "required": true
    },
    "comunidade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::comunidade.comunidade",
      "inversedBy": "fieis"
    },
    "coletas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::coleta.coleta",
      "mappedBy": "fiel"
    },
    "dizimos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::dizimo.dizimo",
      "mappedBy": "fiel"
    }
  }
